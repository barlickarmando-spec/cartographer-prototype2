# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Session secret: must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET="your-32-char-minimum-secret-here"

# Optional: TESTING-ONLY demo auth (no DB). Set to "1" to enable. Do not use in production.
# DEMO_AUTH=1

# RapidAPI Key for Zillow integration
# Get your key at: https://rapidapi.com/apimaker/api/zillow56
RAPIDAPI_KEY="your-rapidapi-key-here"

# Google Custom Search API (fallback for home images when Realtor.com API is unavailable)
# 1. Enable "Custom Search API" at: https://console.cloud.google.com/apis/library/customsearch.googleapis.com
# 2. Create an API key at: https://console.cloud.google.com/apis/credentials
# 3. Create a search engine at: https://programmablesearchengine.google.com/ (enable "Search the entire web")
# Free tier: 100 queries/day
GOOGLE_API_KEY="your-google-api-key-here"
GOOGLE_SEARCH_ENGINE_ID="your-search-engine-cx-id-here"
